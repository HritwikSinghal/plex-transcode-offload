#!/usr/bin/env python3
"""
prt-transcoder — Plex Remote Transcoder wrapper.

Drops in for `/usr/lib/plexmediaserver/Plex Transcoder` on the master.
Forwards every invocation to the worker over SSH (using a persistent
ControlMaster connection), executes the real transcoder there with the
same argv + env + cwd, and streams stdio + signals back.

Design points:
  * Zero-state. Each invocation is independent. Persistence comes from
    SSH ControlMaster (managed by prt-ssh-keepalive.service) which keeps
    the TCP+SSH handshake out of the hot path.
  * Identical filesystem layout. Media + transcode temp dir must live at
    the same path on master and worker (NFS makes this trivial). No
    path translation is performed.
  * Bounded env forwarding. We forward only env vars Plex actually uses,
    plus a small allowlist. This keeps the remote command line under
    ARG_MAX and avoids leaking unrelated state.
  * Faithful signal forwarding. SIGTERM/SIGINT/SIGHUP/SIGQUIT propagate
    to ssh, which (with -tt) relays them to the remote process group.
"""

from __future__ import annotations

import configparser
import os
import shlex
import signal
import subprocess
import sys
import syslog
from pathlib import Path

CONFIG_PATHS = (
    Path("/etc/prt/prt.conf"),
    Path.home() / ".config" / "prt" / "prt.conf",
)

# Exit code the worker-side shim (prt-worker-transcoder) returns when the
# master's expected Plex version (PRT_EXPECTED_PLEX_VERSION, forwarded below)
# does not match the version installed on the worker. EX_CONFIG from sysexits.
# The master treats it as a distinct, loudly-logged reason to fall back locally.
# Until the worker half implements the check this code is never emitted, so
# recognizing it here is backward-safe.
VERSION_SKEW_RC = 78

# ssh's own transport-error exit code (connection/auth failure, not a remote
# command exit). Historically the ONLY trigger for local fallback.
SSH_TRANSPORT_RC = 255

# Env vars Plex Media Server passes to the transcoder that the remote
# binary needs to behave identically. Prefix matches are checked first,
# then exact names.
ENV_PREFIX_ALLOWLIST = ("X_PLEX_", "PLEX_", "FFMPEG_", "XDG_", "LC_")
ENV_NAME_ALLOWLIST = frozenset(
    {
        "LANG",
        "LD_LIBRARY_PATH",
        "TMPDIR",
        "HOME",
        "PATH",
        "TERM",
        # Master's expected Plex version, so the worker shim can detect skew
        # and exit VERSION_SKEW_RC. Exact name (not a PRT_ prefix) to keep env
        # forwarding bounded.
        "PRT_EXPECTED_PLEX_VERSION",
    }
)


def _log(msg: str) -> None:
    syslog.syslog(syslog.LOG_INFO, f"prt-transcoder: {msg}")


def _die(msg: str, code: int = 1) -> "None":
    syslog.syslog(syslog.LOG_ERR, f"prt-transcoder: {msg}")
    print(f"prt-transcoder: {msg}", file=sys.stderr)
    sys.exit(code)


def _load_config() -> configparser.ConfigParser:
    cfg = configparser.ConfigParser()
    found = [p for p in CONFIG_PATHS if p.is_file()]
    if not found:
        _die(
            f"no config file found (looked at: {', '.join(str(p) for p in CONFIG_PATHS)})"
        )
    cfg.read(found)
    for section in ("worker", "paths"):
        if section not in cfg:
            _die(f"config missing required [{section}] section")
    return cfg


def _should_forward(name: str) -> bool:
    if name in ENV_NAME_ALLOWLIST:
        return True
    return any(name.startswith(p) for p in ENV_PREFIX_ALLOWLIST)


def _build_remote_command(plex_transcoder_path: str) -> str:
    """Build the shell-escaped command string to execute on the worker.

    Form: `cd <cwd> && exec env -i K=V K=V ... -- <transcoder> <argv...>`
    `env -i` wipes the remote login shell's env so only allow-listed vars
    survive; `exec` replaces the shell so signals reach the binary directly.
    """
    env_assigns = " ".join(
        f"{shlex.quote(k)}={shlex.quote(v)}"
        for k, v in sorted(os.environ.items())
        if _should_forward(k)
    )
    argv_quoted = " ".join(shlex.quote(a) for a in sys.argv[1:])
    return (
        f"cd {shlex.quote(os.getcwd())} && "
        f"exec env -i {env_assigns} -- "
        f"{shlex.quote(plex_transcoder_path)} {argv_quoted}"
    )


def _ssh_conn_opts(cfg: configparser.ConfigParser) -> tuple[list[str], str]:
    """Connection-level ssh args shared by the transcode dispatch and the
    health probe, plus the `user@host` target. Excludes `-tt` and the remote
    command, which differ per call site.
    """
    worker = cfg["worker"]
    host = worker["host"]
    user = worker.get("user", "plex")
    ssh_key = worker.get("ssh_key", "").strip()
    control_dir = cfg["paths"].get("ssh_control_dir", "/run/prt").rstrip("/")

    opts = [
        "-o",
        "BatchMode=yes",
        "-o",
        "StrictHostKeyChecking=accept-new",
        "-o",
        f"ControlPath={control_dir}/cm-%r@%h:%p",
        "-o",
        "ControlMaster=auto",
        "-o",
        "ControlPersist=600",
        "-o",
        "ServerAliveInterval=10",
        "-o",
        "ServerAliveCountMax=3",
        # Bound the connect phase so a half-dead worker can't stall dispatch;
        # the persistent ControlMaster means the happy path skips connect
        # entirely, so this only bites when the worker is actually unreachable.
        "-o",
        "ConnectTimeout=5",
    ]
    if ssh_key:
        opts += ["-i", ssh_key]
    return opts, f"{user}@{host}"


def _ssh_argv(cfg: configparser.ConfigParser, remote_command: str) -> list[str]:
    opts, target = _ssh_conn_opts(cfg)
    # -tt forces a remote TTY so the remote process gets SIGHUP when
    # ssh disconnects, ensuring no orphaned transcoders on master crash.
    return ["ssh", *opts, "-tt", target, remote_command]


def _probe_worker(cfg: configparser.ConfigParser) -> bool:
    """Fast reachability check used only on the failure path to label WHY a
    job failed (transport down vs worker-side error) for the log line and the
    future metrics hook. Reuses the ControlMaster socket, so it is near-instant
    when the keepalive connection is up; ConnectTimeout bounds the worst case.
    """
    opts, target = _ssh_conn_opts(cfg)
    try:
        rc = subprocess.call(
            ["ssh", *opts, target, "true"],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    except OSError:
        return False
    return rc == 0


def _evaluate_outcome(rc: int, terminated_by_plex: bool) -> tuple[str, bool]:
    """Pure decision: map a finished dispatch to (reason, want_fallback).

    A Plex-initiated termination (seek/stop) is expected to exit nonzero and
    must NOT trigger fallback -- re-transcoding an abandoned job wastes the
    worker. Every other nonzero outcome warrants a local fallback attempt; the
    specific reason only steers logging/metrics.
    """
    if terminated_by_plex:
        return ("cancelled", False)
    if rc == 0:
        return ("success", False)
    if rc == VERSION_SKEW_RC:
        return ("version_skew", True)
    if rc == SSH_TRANSPORT_RC:
        return ("transport_error", True)
    return ("worker_error", True)


def _fallback_local(cfg: configparser.ConfigParser) -> int:
    """Optional local fallback when the worker can't serve the job."""
    if not cfg["worker"].getboolean("fallback_local", fallback=False):
        return -1
    local_bin = cfg["paths"].get("plex_transcoder_backup")
    if not local_bin or not Path(local_bin).is_file():
        _log("fallback requested but no backup binary configured/present")
        return -1
    _log(f"falling back to local transcoder at {local_bin}")
    return subprocess.call([local_bin, *sys.argv[1:]])


def main() -> int:
    syslog.openlog("prt-transcoder", syslog.LOG_PID, syslog.LOG_DAEMON)
    cfg = _load_config()

    plex_transcoder_path = cfg["paths"].get(
        "plex_transcoder", "/usr/lib/plexmediaserver/Plex Transcoder"
    )
    remote_cmd = _build_remote_command(plex_transcoder_path)
    ssh_cmd = _ssh_argv(cfg, remote_cmd)

    _log(f"dispatch to {cfg['worker']['host']}: argv={len(sys.argv)-1} args")

    try:
        proc = subprocess.Popen(
            ssh_cmd,
            stdin=sys.stdin,
            stdout=sys.stdout,
            stderr=sys.stderr,
            close_fds=True,
        )
    except FileNotFoundError:
        _die("ssh not found; install openssh-client on the master")
    except OSError as e:
        rc = _fallback_local(cfg)
        if rc >= 0:
            return rc
        _die(f"failed to launch ssh: {e}", code=69)  # EX_UNAVAILABLE

    # Terminating signals mean Plex deliberately stopped this transcode (seek,
    # stop, session teardown). We must remember that so the nonzero exit it
    # produces is NOT mistaken for a worker failure and re-run locally.
    state = {"terminated_by_plex": False}
    TERMINATING = frozenset(
        {signal.SIGTERM, signal.SIGINT, signal.SIGHUP, signal.SIGQUIT}
    )

    # Forward catchable signals to the ssh process (which propagates them
    # to the remote process group thanks to -tt).
    def _forward(signum: int, _frame) -> None:
        if signum in TERMINATING:
            state["terminated_by_plex"] = True
        try:
            proc.send_signal(signum)
        except ProcessLookupError:
            pass

    for sig in (
        signal.SIGTERM,
        signal.SIGINT,
        signal.SIGHUP,
        signal.SIGQUIT,
        signal.SIGUSR1,
        signal.SIGUSR2,
    ):
        signal.signal(sig, _forward)

    try:
        rc = proc.wait()
    except KeyboardInterrupt:
        state["terminated_by_plex"] = True
        proc.send_signal(signal.SIGINT)
        rc = proc.wait()

    reason, want_fallback = _evaluate_outcome(rc, state["terminated_by_plex"])

    # Version skew is operator-actionable (the master and worker Plex pins
    # drifted) -- surface it loudly rather than burying it in a generic line.
    if reason == "version_skew":
        skew_msg = (
            f"worker reported Plex version skew (rc={rc}); the worker's "
            "transcoder version does not match PRT_EXPECTED_PLEX_VERSION. "
            "Re-pin both nodes to the same Plex version."
        )
        syslog.syslog(syslog.LOG_ERR, f"prt-transcoder: {skew_msg}")
        print(f"prt-transcoder: {skew_msg}", file=sys.stderr)

    if want_fallback:
        worker_up = _probe_worker(cfg)
        _log(
            f"remote transcode failed rc={rc} reason={reason} "
            f"worker_reachable={worker_up}; attempting local fallback"
        )
        local_rc = _fallback_local(cfg)
        if local_rc >= 0:
            _log(f"local fallback finished rc={local_rc}")
            return local_rc

    _log(f"transcode finished rc={rc} reason={reason}")
    return rc


if __name__ == "__main__":
    sys.exit(main())
